Options -Indexes -MultiViews
DirectoryIndex index.html
DirectorySlash Off

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /slotify/

  # Allow direct access to _next static assets (CSS, JS, fonts, images)
  RewriteRule ^_next/ - [L]

  # Allow Next.js RSC / internal data files (files starting with __next)
  RewriteRule ^__next - [L]

  # If the request is for an exact file that exists, serve it
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # If the request is for a directory with an index.html, serve it directly (NO redirect)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^ %{REQUEST_FILENAME}/index.html [L]

  # Fallback: serve the root index.html (Next.js client-side routing handles the rest)
  RewriteRule ^ /slotify/index.html [L]
</IfModule>

# Ensure files starting with underscores/dots are accessible
<FilesMatch "^(__next|_next|\.)">
  Allow from all
  Satisfy Any
</FilesMatch>
